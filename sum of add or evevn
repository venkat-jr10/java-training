import java.util.*;
class Main {
    public static void main(String[] args) {
        int sum=0;
        int n;
        Scanner s=new Scanner(System.in);
        n=s.nextInt();
        for(int i=1;i<=n;i++)
        {
            if(i%2==0)
          sum=sum+i;
        }
        System.out.println(sum); 
    }
}
