import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int n,sum,i;
        Scanner s=new Scanner(System.in);
        n=s.nextInt();
        sum=0;
        for(i=1;i<=n;i++){
            sum=sum+i;
        }
        System.out.println(sum);
    }
}
