import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        int mult,i,n;
        Scanner s = new Scanner(System.in);
        n= s.nextInt();
        i=1;
        mult=0;
        for ( i = 1; i <= 10; i++) {    
            mult= i * n;
        System.out.println(i + "*" + n + "=" + mult);
        }
    }
